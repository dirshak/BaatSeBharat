# Groq — used by src/models/llm_topic_classifier.py to classify each
# speech's dominant topic against the tracked company universe.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional LLM providers already supported by src/prediction_engine.py's
# TradingAgents-backed "LLM Mode" (see TradingAgents/.env.example for the
# full list TradingAgents itself understands).
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
